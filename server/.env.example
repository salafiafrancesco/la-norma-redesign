# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────
# REQUIRED in production. Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars

# ── Admin credentials ─────────────────────────────────────────
# Used only on first startup to create the admin user.
# Change both before going live!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# ── CORS ─────────────────────────────────────────────────────
# Your production frontend URL, no trailing slash.
CORS_ORIGIN=https://la-norma-redesign.vercel.app
