# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────
# Generate a strong secret:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars

# ── Admin credentials ─────────────────────────────────────────
# Change both before going live!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# ── CORS ─────────────────────────────────────────────────────
# Your production frontend URL(s), comma-separated, no trailing slash.
# Example: https://www.lanormaristorante.com,https://lanormaristorante.com
ALLOWED_ORIGINS=https://www.yourdomain.com
