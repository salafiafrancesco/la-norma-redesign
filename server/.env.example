# ── Server ────────────────────────────────────────────────────
PORT=3001
NODE_ENV=production

# ── Security ─────────────────────────────────────────────────
# REQUIRED in production. Generate with:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-minimum-32-chars

# ── Admin credentials ─────────────────────────────────────────
# Used on first startup to create the admin user in db.json.
# If db.json already exists, these values are ignored.
# To reset: delete db.json via Render Shell, then restart the service.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-strong-password

# ── CORS ─────────────────────────────────────────────────────
# Production frontend URL, no trailing slash.
CORS_ORIGIN=https://la-norma-redesign.vercel.app
