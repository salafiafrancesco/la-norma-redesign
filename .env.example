# ─────────────────────────────────────────────────────────────
# La Norma — Environment Variables
# Set these in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Leave EMPTY — backend runs as Vercel serverless function on same origin.
VITE_API_URL=

# Supabase connection (get from Supabase Dashboard → Settings → API)
SUPABASE_URL=https://tlnlibqjzdrynlzbtqam.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# JWT secret for admin auth. Generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=

# Admin credentials (used on first startup to seed the admin user)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
