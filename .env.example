# ─────────────────────────────────────────────────────────────
# La Norma — Frontend Environment Variables (Vite)
# Set these in Vercel Dashboard → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Full URL of the backend API (no trailing slash).
# Leave EMPTY in local development (Vite proxy handles /api).
# In production: your Render backend URL.
# Example: https://la-norma-api.onrender.com
VITE_API_URL=
