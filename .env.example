# Frontend
# Leave empty in local development when Vite proxies /api to the backend.
VITE_API_URL=https://la-norma-redesign.onrender.com

# Backend
JWT_SECRET=replace-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password

# Optional persistence overrides for production environments.
# DATA_DIR=/absolute/path/to/persistent/data
# DB_PATH=/absolute/path/to/persistent/data/db.json
# UPLOADS_DIR=/absolute/path/to/persistent/uploads

# Optional CORS configuration.
# CORS_ORIGIN=https://www.lanormarestaurant.com
# ALLOWED_ORIGINS=https://www.lanormarestaurant.com,https://admin.example.com
