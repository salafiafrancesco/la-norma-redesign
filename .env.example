# ── Frontend Environment Variables ───────────────────────────
# Copy this file to .env.local for local development.
#
# VITE_API_URL:
#   - Development: leave empty (Vite proxy forwards /api/* to localhost:3001)
#   - Production:  REQUIRED — set to your Render backend URL, no trailing slash.
#
# In Vercel: Settings → Environment Variables → VITE_API_URL
VITE_API_URL=https://la-norma-redesign.onrender.com
