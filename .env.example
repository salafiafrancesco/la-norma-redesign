# ── Frontend Environment Variables ───────────────────────────
# Copy this file to .env.local for local development.
#
# VITE_API_URL:
#   - Development: leave empty (Vite proxy forwards /api/* to localhost:3001)
#   - Production:  set to your backend URL, no trailing slash
#     Example: https://la-norma-api.onrender.com
VITE_API_URL=
